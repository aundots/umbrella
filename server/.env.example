PORT=3001

# 공공데이터포털(data.go.kr) 기상청 API — Encoding(인코딩) 키 사용
# 동일 키로 아래 API 각각 활용신청 필요 (마이페이지 → 활용신청 현황)
# 1) 초단기실황·초단기예보 (VilageFcstInfoService_2.0) — relay 기본
# 2) 동네예보 (getVilageFcst) — POP·기온·습도 등 상세 예보
# 3) 레이더영상 조회 (RadarImgInfoService/getCmpImg) — 레이더 화면
DATA_GO_KR_SERVICE_KEY=your_encoding_service_key

# mTLS (앱인토스 콘솔에서 발급) — 로컬은 파일 경로, Vercel은 PEM 본문 env 권장
# MTLS_CERT_PATH=./mtls/weather_public.crt
# MTLS_KEY_PATH=./mtls/weather_private.key
# MTLS_CERT_PEM=-----BEGIN CERTIFICATE-----\n...
# MTLS_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...
# Vercel에서 줄바꿈이 깨지면 base64 한 줄로 넣기 (권장):
# MTLS_CERT_PEM_B64=base64(weather_public.crt 전체)
# MTLS_KEY_PEM_B64=base64(weather_private.key 전체)

# TOSS_API_BASE_URL=https://apps-in-toss-api.toss.im
# TOSS_PUSH_TEMPLATE_CODE=umbrella_rain_alert (내용: {{ msg }} 비 와요.)
# TOSS_PUSH_TEMPLATE_CODE_CLEAR=umbrella_rain_clear (내용: {{ msg }} 비 그쳤어요.)
# TOSS_DEPLOYMENT_ID=ait_빌드_deploymentId (테스트 푸시용)

# DB 영구 저장 (Upstash Redis 무료 — Vercel Hobby OK, Pro 불필요)
# https://console.upstash.com → Redis 생성 → REST API
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...
# Vercel Storage KV 연동 시 자동 env도 동일하게 동작:
# KV_REST_API_URL / KV_REST_API_TOKEN

# Cron 인증 — GitHub Actions(또는 외부 스케줄러)가 Bearer로 전달
# Vercel env + GitHub repo secret CRON_SECRET 둘 다 동일 값 권장
# CRON_SECRET=random_long_secret
