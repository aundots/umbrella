{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm install --prefix server",
  "buildCommand": "npm run build --prefix server",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "server/public/**"
    }
  },
  "crons": [
    {
      "path": "/cron/notify",
      "schedule": "*/5 * * * *"
    }
  ]
}
