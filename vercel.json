{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "umbrella",
  "installCommand": "npm install --prefix server",
  "buildCommand": "npm run build --prefix server",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
